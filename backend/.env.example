# P-Insight Backend — Environment Variables
# -------------------------------------------
# Copy this file to .env and fill in real values before running.
# Never commit your actual .env file to version control.
#
# See DEPLOYMENT.md for the full deployment checklist.

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=P-Insight API
APP_VERSION=0.1.0

# "development" | "staging" | "production"
APP_ENV=development

# Set to false in production — SQL echo + stack traces are exposed when true
DEBUG=false

# ─── Logging ─────────────────────────────────────────────────────────────────
# "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=INFO

# ─── API Docs ────────────────────────────────────────────────────────────────
# Set to true to enable /docs and /redoc (Swagger UI).
# Recommended: false in production, true during development.
DOCS_ENABLED=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Option A — single origin (simple local setup):
FRONTEND_URL=http://localhost:3000

# Option B — comma-separated list (multi-origin / production):
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development — no setup required):
DATABASE_URL=sqlite:///./p_insight.db

# PostgreSQL (production — recommended):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/p_insight
# After switching: pip install psycopg2-binary && alembic upgrade head

# ─── Default Data Mode ───────────────────────────────────────────────────────
# "uploaded" | "live" | "broker" (mock mode is disabled)
DEFAULT_DATA_MODE=uploaded

# ─── Feature Flags ───────────────────────────────────────────────────────────
LIVE_API_ENABLED=true
BROKER_SYNC_ENABLED=false
AI_CHAT_ENABLED=false
ADVANCED_ANALYTICS_ENABLED=false

# Modular feature switches. Disable one feature without taking down the app.
FEATURE_PORTFOLIO_CORE=true
FEATURE_UPLOAD=true
FEATURE_WATCHLIST=true
FEATURE_QUANT=true
FEATURE_FUNDAMENTALS=true
FEATURE_HISTORY=true
FEATURE_MARKET_DATA=true
FEATURE_NEWS=true
FEATURE_ADVISOR=true
FEATURE_BROKER_SYNC=false

# ─── AI Provider Keys ────────────────────────────────────────────────────────
# Provide at least one key to enable the AI Portfolio Advisor.
# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# ─── Market Data Keys (all optional) ─────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
NEWS_API_KEY=

# ─── Broker Integration (scaffolded — not yet implemented) ───────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
