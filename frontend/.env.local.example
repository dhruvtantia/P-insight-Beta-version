# P-Insight Frontend — Environment Variables
# -------------------------------------------
# Copy this file to .env.local and fill in real values.
# Never commit your actual .env.local file to version control.
#
# NEXT_PUBLIC_ prefix exposes variables to the browser bundle.
# Never put secrets (API keys, tokens) in NEXT_PUBLIC_ variables.

# ─── Backend API URL ─────────────────────────────────────────────────────────
# Points the frontend at the FastAPI backend.
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Staging / production — replace with your deployed API URL:
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
#
# Tip: if you're hosting both frontend and backend on the same domain
# and using Next.js rewrites (see next.config.ts), you can set this
# to an empty string and rely on the rewrite rules instead:
# NEXT_PUBLIC_API_URL=
