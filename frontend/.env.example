# P-Insight Frontend Environment
# Copy to the environment file used by the active frontend framework.
# Current repo: Next.js reads .env.local and NEXT_PUBLIC_* variables.
# Target rebuild: Vite reads .env and VITE_* variables.
#
# Never place backend secrets, market data keys, broker keys, payment secrets,
# AI provider keys, or database credentials in frontend environment files.

# Target Vite variables
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=development
VITE_POSTHOG_KEY=
VITE_SENTRY_DSN=

# Current Next.js compatibility
NEXT_PUBLIC_API_URL=http://localhost:8000

